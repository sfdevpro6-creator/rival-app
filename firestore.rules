// ═══════════════════════════════════════════════════════════
// FIRESTORE RULES — Paste this into Firebase Console
// Go to: Firestore Database → Rules tab → Replace all → Publish
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: anyone authenticated can read, only you can write your own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth != null;
    }
    
    // Conversations: only participants can read/write
    match /conversations/{convoId} {
      allow read, write: if request.auth != null 
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      
      // Messages subcollection
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Games: only players can read/write
    match /games/{gameId} {
      allow read, write: if request.auth != null;
    }
    
    // Notifications: recipient can read, anyone auth'd can create
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.to;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.to;
    }
  }
}
